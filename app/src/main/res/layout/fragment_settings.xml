<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="80dp">

        <!-- ── Title ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="20dp"/>

        <!-- ══════════════════════════════════════
             SECTION 1 — Registered SIM
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGISTERED SIM"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"/>

        <!-- SIM 1 Compact Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sim1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/color_sim1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sim"
                    app:tint="@color/color_sim1"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="SIM 1"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_sim1_operator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Operator Name"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_sim1_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone Number"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_sim1_reg_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connected"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_sim1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        android:textSize="10sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="0dp"
                        android:minHeight="28dp"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:strokeColor="@color/color_sim1"
                        android:textColor="@color/color_sim1"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SIM 2 Compact Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sim2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/color_sim2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sim"
                    app:tint="@color/color_sim2"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="SIM 2"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_sim2_operator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Operator Name"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_sim2_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone Number"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_sim2_reg_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connected"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_sim2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        android:textSize="10sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="0dp"
                        android:minHeight="28dp"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:strokeColor="@color/color_sim2"
                        android:textColor="@color/color_sim2"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- No SIM state -->
        <LinearLayout
            android:id="@+id/layout_no_sim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_sim"
                app:tint="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:contentDescription="No SIM"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No SIM found"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Refresh Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh_sim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh SIM Status"
            app:icon="@drawable/ic_sim"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- ══════════════════════════════════════
             SECTION 2 — Preferences
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <!-- Dark Mode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nightlight"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Dark Mode"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark Mode"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Switch to dark theme"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════
             SECTION — System Settings
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM SETTINGS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"/>

        <!-- Battery Optimization Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_battery_optimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_clock"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Battery Optimization"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery Optimization"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_battery_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking status..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Configure"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Autostart Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_autostart_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_settings"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Autostart Settings"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autostart Permission"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable autostart for Xiaomi/Oppo/Vivo/Realme"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Configure"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Overlay Permission Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_overlay_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_phone"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Display over apps"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Display Over Other Apps"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_overlay_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking status..."
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Configure"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════
             SECTION 3 — Sync History
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYNC HISTORY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"/>

        <!-- Sync History Toggle Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sync_history_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_export"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Sync History"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sync History"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_last_sync_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to view last 10 syncs"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_sync_history_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="-90"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Expand"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sync History Content — Initially hidden -->
        <LinearLayout
            android:id="@+id/layout_sync_history_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <!-- History items container -->
            <LinearLayout
                android:id="@+id/layout_sync_history_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Empty state -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sync_history_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No sync history yet.\nTap SYNC on Dashboard to start."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:padding="20dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════
             SECTION 4 — About
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_call_log"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="App Info"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Call Log"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_app_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version 1.0"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════
             SECTION 4 — Account
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/color_missed"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"/>

        <!-- Sign Out Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sign_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#1AFF4444"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_logout"
                    app:tint="@color/color_missed"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Sign Out"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Out"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_missed"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disconnect account from this device"
                        android:textSize="12sp"
                        android:textColor="@color/color_missed"
                        android:alpha="0.8"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="@color/color_missed"
                    android:contentDescription="Action"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
