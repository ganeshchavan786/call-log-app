<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="80dp">

        <!-- ── Title ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="20dp"/>

        <!-- ══════════════════════════════════════
             SECTION 1 — SIM Information
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM INFORMATION"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <!-- SIM Details — Click to expand -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sim_details_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_sim"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="SIM Details"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM Details"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View SIM card information"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <!-- Expand/Collapse arrow -->
                <ImageView
                    android:id="@+id/iv_sim_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="-90"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Expand"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SIM Details Content — Initially hidden -->
        <LinearLayout
            android:id="@+id/layout_sim_details_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        <!-- SIM 1 Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sim1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/color_sim1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SIM 1 Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sim"
                        app:tint="@color/color_sim1"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="SIM 1"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_sim1"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_sim1_network"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_sim_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/color_sim1"/>
                </LinearLayout>

                <!-- Operator Name -->
                <TextView
                    android:id="@+id/tv_sim1_operator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp"/>

                <!-- Info Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Phone Number" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                        <TextView android:id="@+id/tv_sim1_number"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Country" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                        <TextView android:id="@+id/tv_sim1_country"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="?attr/colorOutlineVariant" android:layout_marginBottom="10dp"/>

                <!-- IMEI -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IMEI" android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
                <TextView android:id="@+id/tv_sim1_imei"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:fontFamily="monospace"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SIM 2 Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sim2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/color_sim2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SIM 2 Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sim"
                        app:tint="@color/color_sim2"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="SIM 2"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_sim2"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tv_sim2_network"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_sim_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/color_sim2"/>
                </LinearLayout>

                <!-- Operator Name -->
                <TextView
                    android:id="@+id/tv_sim2_operator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp"/>

                <!-- Info Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Phone Number" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                        <TextView android:id="@+id/tv_sim2_number"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Country" android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                        <TextView android:id="@+id/tv_sim2_country"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="14sp" android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="?attr/colorOutlineVariant" android:layout_marginBottom="10dp"/>

                <!-- IMEI -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IMEI" android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
                <TextView android:id="@+id/tv_sim2_imei"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:fontFamily="monospace"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- No SIM state -->
        <LinearLayout
            android:id="@+id/layout_no_sim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_sim"
                app:tint="?attr/colorOutline"
                android:layout_marginBottom="8dp"
                android:contentDescription="No SIM"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No SIM information available"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Refresh Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_refresh_sim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh SIM Info"
            app:icon="@drawable/ic_sim"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
        <!-- End SIM Details Content -->

        <!-- ══════════════════════════════════════
             SECTION 2 — Preferences
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCES"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <!-- Dark Mode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nightlight"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Dark Mode"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark Mode"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Switch to dark theme"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════
             SECTION 3 — About
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_call_log"
                    app:tint="?attr/colorPrimary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="App Info"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Call Log"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Version 1.0 — Phase 1"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
