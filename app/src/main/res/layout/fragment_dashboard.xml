<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_dashboard"
                app:tint="?attr/colorPrimary"
                android:layout_marginEnd="10dp"
                android:contentDescription="Dashboard"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sync_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync"
                android:textSize="13sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <!-- ── Row 1: Total Calls + Missed Calls ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Total Calls Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_phone"
                        app:tint="?attr/colorOnPrimaryContainer"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Total Calls"/>

                    <TextView
                        android:id="@+id/tv_total_calls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimaryContainer"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Calls"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnPrimaryContainer"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Missed Calls Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFEBEE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_call_missed"
                        app:tint="@color/color_missed"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Missed Calls"/>

                    <TextView
                        android:id="@+id/tv_missed_calls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_missed"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Missed Calls"
                        android:textSize="12sp"
                        android:textColor="@color/color_missed"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Row 2: Incoming + Outgoing ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Incoming Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E8F5E9">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_call_incoming"
                        app:tint="@color/color_incoming"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Incoming Calls"/>

                    <TextView
                        android:id="@+id/tv_incoming_calls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_incoming"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Incoming"
                            android:textSize="12sp"
                            android:textColor="@color/color_incoming"/>

                        <TextView
                            android:id="@+id/tv_incoming_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_incoming"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Outgoing Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E3F2FD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_call_outgoing"
                        app:tint="@color/color_outgoing"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="Outgoing Calls"/>

                    <TextView
                        android:id="@+id/tv_outgoing_calls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_outgoing"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Outgoing"
                            android:textSize="12sp"
                            android:textColor="@color/color_outgoing"/>

                        <TextView
                            android:id="@+id/tv_outgoing_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_outgoing"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Row 3: Rejected (full width) ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFF3E0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_call_rejected"
                    app:tint="@color/color_unknown"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Rejected Calls"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_rejected_calls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_unknown"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rejected Calls"
                        android:textSize="12sp"
                        android:textColor="@color/color_unknown"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_rejected_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_unknown"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Call Breakdown Bar ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Call Breakdown"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp"/>

                <!-- Incoming row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Incoming"
                        android:textSize="13sp"
                        android:textColor="@color/color_incoming"/>

                    <ProgressBar
                        android:id="@+id/pb_incoming"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        android:progressTint="@color/color_incoming"
                        android:progressBackgroundTint="#E0E0E0"
                        android:max="100"
                        android:progress="0"/>

                    <TextView
                        android:id="@+id/tv_breakdown_incoming_pct"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_incoming"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Outgoing row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Outgoing"
                        android:textSize="13sp"
                        android:textColor="@color/color_outgoing"/>

                    <ProgressBar
                        android:id="@+id/pb_outgoing"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        android:progressTint="@color/color_outgoing"
                        android:progressBackgroundTint="#E0E0E0"
                        android:max="100"
                        android:progress="0"/>

                    <TextView
                        android:id="@+id/tv_breakdown_outgoing_pct"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_outgoing"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Missed row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Missed"
                        android:textSize="13sp"
                        android:textColor="@color/color_missed"/>

                    <ProgressBar
                        android:id="@+id/pb_missed"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        android:progressTint="@color/color_missed"
                        android:progressBackgroundTint="#E0E0E0"
                        android:max="100"
                        android:progress="0"/>

                    <TextView
                        android:id="@+id/tv_breakdown_missed_pct"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_missed"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Rejected row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Rejected"
                        android:textSize="13sp"
                        android:textColor="@color/color_unknown"/>

                    <ProgressBar
                        android:id="@+id/pb_rejected"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="10dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="8dp"
                        android:progressTint="@color/color_unknown"
                        android:progressBackgroundTint="#E0E0E0"
                        android:max="100"
                        android:progress="0"/>

                    <TextView
                        android:id="@+id/tv_breakdown_rejected_pct"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_unknown"
                        android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Recent Calls Section ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recent Calls"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_calls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

<!-- Overlay block UI -->
<LinearLayout
    android:id="@+id/layout_subscription_expired"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F8F8F6"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:padding="24dp"
    android:visibility="gone">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeColor="#E24B4A"
        app:strokeWidth="1.5dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_call_rejected"
                app:tint="#E24B4A"
                android:layout_marginBottom="20dp"
                android:contentDescription="Expired Icon"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subscription Expired"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2C2C2A"
                android:layout_marginBottom="10dp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your 7-day free trial or subscription has expired.\nPlease buy/renew the Enterprise Plan to continue using the service."
                android:textSize="13sp"
                android:textColor="#5F5E5A"
                android:lineSpacingMultiplier="1.2"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry_expired_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Check Status"
                app:cornerRadius="12dp"
                android:textColor="#FFFFFF"
                android:backgroundTint="?attr/colorPrimary"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>

</FrameLayout>
