<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:padding="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#EDE7F6"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Circular Icon Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_call_type_container"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#EDE7F6"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:id="@+id/iv_call_type_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone"
                    app:tint="#8E24AA"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Text Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_caller_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unknown Number"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:ellipsize="end"
                    android:singleLine="true"/>

                <TextView
                    android:id="@+id/tv_caller_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+91 00000 00000"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"/>

                <!-- SIM Status Badge Container -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:background="#F3E5F5"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:id="@+id/layout_sim_badge">

                    <ImageView
                        android:id="@+id/iv_overlay_sim_icon"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_sim"
                        app:tint="#8E24AA"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tv_overlay_sim_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM 1 (Checking...)"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#8E24AA"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Close Button -->
            <ImageView
                android:id="@+id/btn_close_overlay"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:padding="6dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                app:tint="#888888"
                android:clickable="true"
                android:focusable="true"
                android:layout_gravity="top"
                android:contentDescription="Close Overlay"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
