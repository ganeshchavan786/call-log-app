<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="3dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_call_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <!-- ── Left: Avatar (Initials or Call Icon) ── -->
            <FrameLayout
                android:id="@+id/fl_avatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Initials circle (contact name असेल तर) -->
                <TextView
                    android:id="@+id/tv_initials"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_circle"
                    android:visibility="gone"/>

                <!-- Call type icon (Unknown number) -->
                <ImageView
                    android:id="@+id/iv_call_type"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:padding="11dp"
                    android:background="@drawable/bg_circle"
                    android:contentDescription="Call type"
                    android:visibility="visible"/>

            </FrameLayout>

            <!-- ── Contact Name ── -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/tv_sim"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- ── Phone Number ── -->
            <TextView
                android:id="@+id/tv_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/tv_sim"
                app:layout_constraintTop_toBottomOf="@id/tv_name"/>

            <!-- ── Call Type Label + Time + Duration ── -->
            <LinearLayout
                android:id="@+id/ll_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/tv_sim"
                app:layout_constraintTop_toBottomOf="@id/tv_number"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Call type label — colored -->
                <TextView
                    android:id="@+id/tv_call_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <!-- Separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Time -->
                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Duration -->
                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ── SIM Badge (top-right) ── -->
            <TextView
                android:id="@+id/tv_sim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_sim_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- ── Deleted badge (bottom-right) ── -->
            <ImageView
                android:id="@+id/iv_deleted_badge"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_call_unknown"
                android:contentDescription="Deleted from phone"
                android:visibility="gone"
                app:tint="#FF9800"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
