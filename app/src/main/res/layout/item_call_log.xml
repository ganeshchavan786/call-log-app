<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="2dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_call_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <!-- ── Left: Avatar (Initials or Call Icon) ── -->
            <FrameLayout
                android:id="@+id/fl_avatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_initials"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_circle"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/iv_call_type"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_circle"
                    android:contentDescription="Call type"
                    android:visibility="visible"/>

            </FrameLayout>

            <!-- ── Right section: SIM badge + 2x2 action buttons ── -->
            <LinearLayout
                android:id="@+id/ll_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- SIM Badge -->
                <TextView
                    android:id="@+id/tv_sim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_sim_badge"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="3dp"/>

                <!-- Row 1: WhatsApp + Call -->
                <LinearLayout
                    android:id="@+id/ll_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btn_whatsapp"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_whatsapp"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="WhatsApp"/>

                    <ImageView
                        android:id="@+id/btn_call"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_phone"
                        app:tint="?attr/colorPrimary"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Call"
                        android:layout_marginStart="2dp"/>

                </LinearLayout>

                <!-- Row 2: SMS + Add Contact -->
                <LinearLayout
                    android:id="@+id/ll_actions2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <ImageView
                        android:id="@+id/btn_sms"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_sms"
                        app:tint="#FF9800"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="SMS"/>

                    <ImageView
                        android:id="@+id/btn_add_contact"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_person_add"
                        app:tint="#00BCD4"
                        android:padding="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Add Contact"
                        android:layout_marginStart="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Deleted badge ── -->
            <ImageView
                android:id="@+id/iv_deleted_badge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_call_unknown"
                android:contentDescription="Deleted from phone"
                android:visibility="gone"
                app:tint="#FF9800"
                app:layout_constraintEnd_toStartOf="@id/ll_right"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"/>

            <!-- ── Contact Name ── -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/ll_right"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- ── Phone Number ── -->
            <TextView
                android:id="@+id/tv_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/ll_right"
                app:layout_constraintTop_toBottomOf="@id/tv_name"/>

            <!-- ── Call Type Label + Time + Duration ── -->
            <LinearLayout
                android:id="@+id/ll_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toEndOf="@id/fl_avatar"
                app:layout_constraintEnd_toStartOf="@id/ll_right"
                app:layout_constraintTop_toBottomOf="@id/tv_number"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tv_call_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
