<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- ── Top Bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Call Logs"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <!-- Total count -->
        <TextView
            android:id="@+id/tv_total_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 calls"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="12dp"/>


        <!-- Sort Button -->
        <ImageView
            android:id="@+id/btn_sort"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_sort"
            android:padding="4dp"
            app:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Sort"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- ── Search Bar ── -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        app:startIconDrawable="@drawable/ic_search"
        app:endIconMode="clear_text"
        app:boxCornerRadiusTopStart="28dp"
        app:boxCornerRadiusTopEnd="28dp"
        app:boxCornerRadiusBottomStart="28dp"
        app:boxCornerRadiusBottomEnd="28dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:paddingVertical="14dp"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Filter Chips with counts ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_incoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming"
                app:chipIcon="@drawable/ic_call_incoming"
                app:chipIconTint="@color/color_incoming"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_outgoing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Outgoing"
                app:chipIcon="@drawable/ic_call_outgoing"
                app:chipIconTint="@color/color_outgoing"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_missed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Missed"
                app:chipIcon="@drawable/ic_call_missed"
                app:chipIconTint="@color/color_missed"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_rejected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rejected"
                app:chipIcon="@drawable/ic_call_rejected"
                app:chipIconTint="@color/color_unknown"
                style="@style/Widget.MaterialComponents.Chip.Filter"/>

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- ── Divider ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.3"/>

    <!-- ── Empty State ── -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_call_log"
            app:tint="?attr/colorOutline"
            android:layout_marginBottom="16dp"
            android:contentDescription="No calls"/>

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_calls"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync your call logs from Dashboard"
            android:textSize="13sp"
            android:textColor="?attr/colorOutline"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ── Call Logs List ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_call_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="80dp"/>

</LinearLayout>
